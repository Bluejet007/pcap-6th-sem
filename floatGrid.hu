void FloatGrid::debugReserves() {
    std::cout << "Reserves amount: " << +reservesAmt << std::endl;

    for(uint8_t i = 0; i < reservesAmt; i++) {
        std::cout << +i << std::endl << "Allocated: " << (reserveUsed[i] ? "true" : "false") << std::endl;

        if(reserveUsed[i]) {
            std::cout << "Size: " << reserveSize[i] / sizeof(float4) << std::endl << "Size (in bytes): " << reserveSize[i] << std::endl << "Raw pointer: " << reserves[i] << std::endl;
        }
        std::cout << std::endl;
    }
}


/* Destructor */
FloatGrid::~FloatGrid() {
    reserveUsed[rIdx] = false;
}

#endif